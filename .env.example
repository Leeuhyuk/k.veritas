# ---- Server ----
PORT=3000
NODE_ENV=development
SESSION_SECRET=change-me-to-a-long-random-string
# ADMIN_PASSWORD=only-used-when-data-admin-json-missing

# HTTPS behind reverse proxy
# TRUST_PROXY=1
# COOKIE_SECURE=1

# ---- Firebase (production-management-e70fd) ----
# 1로 설정하고 자격증명이 있어야 Firestore/Storage 사용
USE_FIREBASE=0
FIREBASE_PROJECT_ID=production-management-e70fd
# Storage 버킷 (콘솔 기본 .appspot.com 이 없으면 커스텀 버킷 사용)
FIREBASE_STORAGE_BUCKET=production-management-e70fd-media

# 서비스 계정 JSON 경로 (권장)
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → 새 비공개 키
GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccount.json

# 또는 JSON 문자열로 직접 (비권장·CI용)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ---- 관리자 구글 로그인 (Firebase Authentication) ----
# 1) Firebase 콘솔 → Authentication → Sign-in method → Google 사용 설정
# 2) 프로젝트 설정 → 내 앱 → 웹 앱 추가 후 설정값 복사
# 3) 허용할 관리자 구글 이메일을 쉼표로 나열
ADMIN_GOOGLE_EMAILS=you@gmail.com
FIREBASE_WEB_API_KEY=
FIREBASE_AUTH_DOMAIN=production-management-e70fd.firebaseapp.com
FIREBASE_WEB_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=
# 참고: 웹 콘솔 storageBucket 이 *.firebasestorage.app 이어도
# 실제 파일은 FIREBASE_STORAGE_BUCKET(커스텀 미디어 버킷) 사용
