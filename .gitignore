# dependencies
node_modules/
admin-app/node_modules/
public-ui/node_modules/

# env & secrets
.env
.env.*
!.env.example
secrets/*
!secrets/README.md
!secrets/.gitkeep
serviceAccount.json
**/serviceAccount*.json

# logs
*.log
server-out.log
server-err.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo

# local uploads (keep folder, ignore content)
uploads/*
!uploads/.gitkeep
private_uploads/*
!private_uploads/.gitkeep

# optional local data backups
data/*.bak
data/*~

# build caches
# admin SPA 는 서버 필요 — dist 는 로컬 빌드
admin-app/dist/
# public-ui dist 는 GitHub Pages 공개 목록용으로 커밋
# public-ui/dist/
*.tsbuildinfo

# agent / local tooling
.claude/
.grok/
